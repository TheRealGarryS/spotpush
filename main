// ==========================================
// 🔑 PASTE YOUR SPOTIFY DEVELOPER KEYS HERE
// ==========================================
const CLIENT_ID = '';
const CLIENT_SECRET = '';

/**
 * Configures the Spotify OAuth2 service.
 */
function getSpotifyService() {
  return OAuth2.createService('Spotify')
      .setAuthorizationBaseUrl('https://accounts.spotify.com/authorize')
      .setTokenUrl('https://accounts.spotify.com/api/token')
      .setClientId(CLIENT_ID)
      .setClientSecret(CLIENT_SECRET)
      .setCallbackFunction('authCallback')
      .setPropertyStore(PropertiesService.getUserProperties())
      .setScope('playlist-modify-public playlist-modify-private');
}

/**
 * Handles the OAuth callback.
 */
function authCallback(request) {
  var service = getSpotifyService();
  var authorized = service.handleCallback(request);
  if (authorized) {
    return HtmlService.createHtmlOutput('Success! You can close this tab.');
  } else {
    return HtmlService.createHtmlOutput('Denied. Check your settings.');
  }
}

/**
 * Logs the Link you need to paste into your Spotify Developer Dashboard.
 */
function logRedirectUri() {
  console.log(getSpotifyService().getRedirectUri());
}

/**
 * Check connection trigger.
 */
function checkSpotifyConnection() {
  var service = getSpotifyService();
  if (service.hasAccess()) {
    Logger.log("Connected! You are ready to build playlists.");
    SpreadsheetApp.getUi().alert("Connected! You are ready to build playlists.");
  } else {
    var authorizationUrl = service.getAuthorizationUrl();
    Logger.log("Open this URL to connect: " + authorizationUrl);
    SpreadsheetApp.getUi().alert("Check execution logs (Ctrl+Enter) for your login URL.");
  }
}

/**
 * Creates a custom UI menu when the sheet is opened.
 */
function onOpen() {
  var ui = SpreadsheetApp.getUi();
  ui.createMenu('🎵 Spotify Engine')
      .addItem('Verify Spotify Connection', 'checkSpotifyConnection')
      .addSeparator()
      .addItem('🚀 Create Brand New Playlist From THIS Tab', 'createDynamicPlaylistFromActiveTab')
      .addToUi();
}

/**
 * Reads the current open tab, gathers URIs from Column F, and provisions a brand-new playlist.
 */
function createDynamicPlaylistFromActiveTab() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const activeSheet = ss.getActiveSheet(); 
  const sheetName = activeSheet.getName();

  // 1. Fetch Custom Playlist Title from cell I3
  const playlistName = activeSheet.getRange("I3").getValue().toString().trim();
  
  if (!playlistName) {
    SpreadsheetApp.getUi().alert(
      `❌ Error: Please type a playlist name in cell I3 before running.`
    );
    return;
  }

  // 2. Authenticate
  const service = getSpotifyService();
  if (!service.hasAccess()) {
    SpreadsheetApp.getUi().alert("Spotify NOT connected. Go to 🎵 Spotify Engine > Verify Spotify Connection.");
    return;
  }
  const token = service.getAccessToken();

  // 3. Find boundaries based on Column F (Spotify URIs)
  const lastRow = activeSheet.getLastRow();
  if (lastRow < 2) {
    SpreadsheetApp.getUi().alert(`The "${sheetName}" tab has no song data found.`);
    return;
  }

  // Grab all values from Column F starting at row 2 down to the last row
  const uriValues = activeSheet.getRange(2, 6, lastRow - 1, 1).getValues();
  let trackUris = [];

  // Filter out empty rows and make sure they look like valid Spotify URIs
  uriValues.forEach((row) => {
    const uri = String(row[0]).trim();
    if (uri && (uri.startsWith('spotify:track:') || uri.length > 15)) {
      trackUris.push(uri);
    }
  });

  if (trackUris.length === 0) {
    SpreadsheetApp.getUi().alert("❌ Aborted: No valid Spotify URIs found in Column F.");
    return;
  }

  // 4. POST to Spotify to create a fresh playlist asset
  const playlistRes = UrlFetchApp.fetch("https://api.spotify.com/v1/me/playlists", {
    method: "post",
    contentType: "application/json",
    headers: { Authorization: "Bearer " + token },
    muteHttpExceptions: true,
    payload: JSON.stringify({
      name: playlistName,
      public: true,
      description: `Generated on-demand from Google Sheet tab: ${sheetName}`
    })
  });

  if (playlistRes.getResponseCode() < 200 || playlistRes.getResponseCode() >= 300) {
    SpreadsheetApp.getUi().alert("Error creating playlist: " + playlistRes.getContentText());
    return;
  }

  const playlistData = JSON.parse(playlistRes.getContentText());
  const newPlaylistId = playlistData.id;

  // 5. Push URIs directly from Column F to the new playlist
  const addTracksRes = UrlFetchApp.fetch(`https://api.spotify.com/v1/playlists/${newPlaylistId}/tracks`, {
    method: "post",
    contentType: "application/json",
    headers: { Authorization: "Bearer " + token },
    muteHttpExceptions: true,
    payload: JSON.stringify({ uris: trackUris })
  });

  if (addTracksRes.getResponseCode() >= 200 && addTracksRes.getResponseCode() < 300) {
    SpreadsheetApp.getUi().alert(
      `🎉 Success!\n\nCreated new playlist: "${playlistName}"\nAdded ${trackUris.length} tracks directly from Column F!`
    );
  } else {
    SpreadsheetApp.getUi().alert("Playlist created, but pushing tracks failed. Check logs.");
  }
}
